{
  "info": {
    "_postman_id": "91d8af16-20bf-4aa5-b44d-delhivery-b2b",
    "name": "Express Magic - Delhivery B2B (LTL)",
    "description": "End-to-end checks for the admin-only Express Magic Delhivery B2B proxy. Save credentials in Admin > Courier Credentials first. Password Reset, Manifest, Update, Cancellation, Pickup, and Appointment requests mutate Delhivery state; run them deliberately.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [{ "key": "token", "value": "{{adminToken}}", "type": "string" }]
  },
  "event": [
    {
      "listen": "test",
      "script": {
        "type": "text/javascript",
        "exec": [
          "pm.test('HTTP status is successful', function () {",
          "  pm.expect(pm.response.code).to.be.within(200, 299);",
          "});",
          "var body = {};",
          "try { body = pm.response.json(); } catch (e) {}",
          "pm.test('proxy reports success', function () {",
          "  pm.expect(body.success).to.eql(true);",
          "});"
        ]
      }
    }
  ],
  "item": [
    {
      "name": "Authentication",
      "item": [
        {
          "name": "Password Reset (manual, mutating)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/delhivery/b2b/auth/password-reset",
            "description": "Sends a reset link for the registered Delhivery username. Do not include this request in routine collection runs.",
            "body": { "mode": "raw", "raw": "{\n  \"username\": \"{{delhiveryUsername}}\"\n}" }
          }
        },
        {
          "name": "Login / Validate Saved Credentials",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/delhivery/b2b/auth/login",
            "description": "Validates the saved Delhivery username/password. Express Magic caches the returned JWT until shortly before its 24-hour expiry and never exposes it to the browser. Concurrent courier requests share a single login call."
          }
        }
      ]
    },
    {
      "name": "Serviceability and Freight",
      "item": [
        {
          "name": "Pincode Serviceability",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/delhivery/b2b/serviceability/{{destinationPincode}}?weight={{weightGrams}}",
            "description": "Checks a six-digit pincode before any shipment operation. Weight is optional and expressed in grams. Express Magic checks both origin and consignee pincodes before B2B manifestation."
          }
        },
        {
          "name": "Expected TAT",
          "request": { "method": "GET", "url": "{{baseUrl}}/api/delhivery/b2b/tat?origin_pin={{originPincode}}&destination_pin={{destinationPincode}}" }
        },
        {
          "name": "Freight Estimate",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/delhivery/b2b/freight/estimate",
            "body": { "mode": "raw", "raw": "{\n  \"dimensions\": [{\"length_cm\": 10, \"width_cm\": 10, \"height_cm\": 10, \"box_count\": 1}],\n  \"weight_g\": {{weightGrams}},\n  \"cheque_payment\": false,\n  \"source_pin\": \"{{originPincode}}\",\n  \"consignee_pin\": \"{{destinationPincode}}\",\n  \"payment_mode\": \"prepaid\",\n  \"inv_amount\": 1000,\n  \"freight_mode\": \"fop\",\n  \"rov_insurance\": false\n}" }
          }
        },
        {
          "name": "Freight Charge Breakup",
          "request": { "method": "GET", "url": "{{baseUrl}}/api/delhivery/b2b/freight/charges?lrns={{lrn}}" }
        }
      ]
    },
    {
      "name": "Warehouses",
      "item": [
        {
          "name": "Create Warehouse (mutating)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/delhivery/b2b/warehouses",
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"{{warehouseName}}\",\n  \"pin_code\": \"{{originPincode}}\",\n  \"city\": \"Gurugram\",\n  \"state\": \"Haryana\",\n  \"country\": \"India\",\n  \"address_details\": {\"address\": \"Test warehouse address\", \"contact_person\": \"Operations\", \"phone_number\": \"9999999999\"}\n}" }
          }
        },
        {
          "name": "Update Warehouse (mutating)",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/delhivery/b2b/warehouses",
            "body": { "mode": "raw", "raw": "{\n  \"cl_warehouse_name\": \"{{warehouseName}}\",\n  \"update_dict\": {\"address_details\": {\"contact_person\": \"Operations Team\", \"phone_number\": \"9999999999\"}}\n}" }
          }
        }
      ]
    },
    {
      "name": "Shipments",
      "item": [
        {
          "name": "Manifest Shipment (mutating)",
          "event": [{
            "listen": "test",
            "script": { "type": "text/javascript", "exec": [
              "var body = pm.response.json();",
              "var data = body.data || {};",
              "var jobId = data.job_id || data.request_id || (data.data || {}).job_id;",
              "var lrn = data.lrn || data.lrnum || (data.data || {}).lrn;",
              "if (jobId) pm.environment.set('manifestJobId', jobId);",
              "if (lrn) pm.environment.set('lrn', lrn);"
            ] }
          }],
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/delhivery/b2b/shipments/manifest",
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "pickup_location_name", "value": "{{warehouseName}}", "type": "text" },
                { "key": "payment_mode", "value": "prepaid", "type": "text" },
                { "key": "weight", "value": "{{weightGrams}}", "type": "text" },
                { "key": "dropoff_location", "value": "{\"consignee_name\":\"Postman Test\",\"address\":\"Test address\",\"city\":\"Mumbai\",\"state\":\"Maharashtra\",\"zip\":\"{{destinationPincode}}\",\"phone\":\"9999999999\",\"email\":\"test@example.com\"}", "type": "text" },
                { "key": "shipment_details", "value": "[{\"order_id\":\"POSTMAN-{{$timestamp}}\",\"box_count\":1,\"description\":\"Postman test shipment\",\"weight\":{{weightGrams}},\"waybills\":[],\"master\":true}]", "type": "text" },
                { "key": "dimensions", "value": "[{\"box_count\":1,\"length\":10,\"width\":10,\"height\":10}]", "type": "text" },
                { "key": "invoices", "value": "[{\"ewaybill\":\"\",\"inv_num\":\"POSTMAN-INV-{{$timestamp}}\",\"inv_amt\":1000,\"inv_qr_code\":\"\"}]", "type": "text" },
                { "key": "rov_insurance", "value": "false", "type": "text" },
                { "key": "freight_mode", "value": "fop", "type": "text" },
                { "key": "fm_pickup", "value": "false", "type": "text" }
              ]
            }
          }
        },
        {
          "name": "Manifest Status",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "var body = pm.response.json(); var data = body.data || {}; var lrn = data.lrn || data.lrnum || (data.data || {}).lrn; if (lrn) pm.environment.set('lrn', lrn);"
          ] } }],
          "request": { "method": "GET", "url": "{{baseUrl}}/api/delhivery/b2b/shipments/manifest/{{manifestJobId}}" }
        },
        {
          "name": "Update Shipment (mutating)",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "var body = pm.response.json(); var data = body.data || {}; var id = data.job_id || data.request_id || (data.data || {}).job_id; if (id) pm.environment.set('updateJobId', id);"
          ] } }],
          "request": {
            "method": "PUT",
            "url": "{{baseUrl}}/api/delhivery/b2b/shipments/{{lrn}}",
            "body": { "mode": "formdata", "formdata": [
              { "key": "consignee_name", "value": "Postman Updated Consignee", "type": "text" },
              { "key": "consignee_phone", "value": "9999999999", "type": "text" }
            ] }
          }
        },
        {
          "name": "Shipment Update Status",
          "request": { "method": "GET", "url": "{{baseUrl}}/api/delhivery/b2b/shipments/update/{{updateJobId}}" }
        },
        {
          "name": "Track Shipment",
          "request": { "method": "GET", "url": "{{baseUrl}}/api/delhivery/b2b/shipments/{{lrn}}/tracking?all_wbns=true" }
        },
        {
          "name": "Book Last-Mile Appointment (mutating)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/delhivery/b2b/shipments/{{lrn}}/appointments",
            "body": { "mode": "raw", "raw": "{\n  \"date\": \"{{appointmentDate}}\",\n  \"appointment_slot\": \"12:00 PM-03:00 PM\",\n  \"po_number\": [\"NotApplicable\"],\n  \"appointment_id\": \"\",\n  \"po_expiry_date\": \"{{appointmentExpiryDate}}\"\n}" }
          }
        },
        {
          "name": "Cancel Shipment (destructive)",
          "request": { "method": "DELETE", "url": "{{baseUrl}}/api/delhivery/b2b/shipments/{{lrn}}" }
        }
      ]
    },
    {
      "name": "Pickups",
      "item": [
        {
          "name": "Create Pickup (mutating)",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "var body = pm.response.json(); var data = body.data || {}; var id = data.pickup_id || data.pur_id || (data.data || {}).pickup_id; if (id) pm.environment.set('pickupId', id);"
          ] } }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/delhivery/b2b/pickups",
            "body": { "mode": "raw", "raw": "{\n  \"client_warehouse\": \"{{warehouseName}}\",\n  \"pickup_date\": \"{{pickupDate}}\",\n  \"start_time\": \"10:00:00\",\n  \"expected_package_count\": 1\n}" }
          }
        },
        {
          "name": "Cancel Pickup (destructive)",
          "request": { "method": "DELETE", "url": "{{baseUrl}}/api/delhivery/b2b/pickups/{{pickupId}}" }
        }
      ]
    },
    {
      "name": "Labels and Documents",
      "item": [
        {
          "name": "Shipping Label",
          "request": { "method": "GET", "url": "{{baseUrl}}/api/delhivery/b2b/shipments/{{lrn}}/labels/a4" }
        },
        {
          "name": "LR Copy",
          "request": { "method": "GET", "url": "{{baseUrl}}/api/delhivery/b2b/shipments/{{lrn}}/lr-copy?lr_copy_type=SHIPPER%20COPY,LM%20POD" }
        },
        {
          "name": "Generate Shipping Labels (async)",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "var body = pm.response.json(); var data = body.data || {}; var id = data.job_id || data.request_id || (data.data || {}).job_id; if (id) pm.environment.set('documentJobId', id);"
          ] } }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/delhivery/b2b/documents/shipping_label",
            "body": { "mode": "raw", "raw": "{\n  \"lrns\": [\"{{lrn}}\"],\n  \"size\": \"a4\",\n  \"callback\": {\"uri\": \"{{documentCallbackUrl}}\", \"method\": \"POST\"}\n}" }
          }
        },
        {
          "name": "Generate LR Copies (async)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/delhivery/b2b/documents/lr_copy",
            "body": { "mode": "raw", "raw": "{\n  \"lrns\": [\"{{lrn}}\"],\n  \"lr_copy_type\": [\"SHIPPER COPY\", \"LM POD\"],\n  \"callback\": {\"uri\": \"{{documentCallbackUrl}}\", \"method\": \"POST\"}\n}" }
          }
        },
        {
          "name": "Generate Document Status",
          "request": { "method": "GET", "url": "{{baseUrl}}/api/delhivery/b2b/documents/shipping_label/{{documentJobId}}" }
        },
        {
          "name": "Download POD Document",
          "request": { "method": "GET", "url": "{{baseUrl}}/api/delhivery/b2b/documents?lrn={{lrn}}&doc_type=LM_POD&auto_download=false&version=latest" }
        }
      ]
    },
    {
      "name": "Session Cleanup",
      "item": [
        {
          "name": "Logout (optional)",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/delhivery/b2b/auth/logout",
            "description": "Invalidates the cached Delhivery JWT. This API is optional and should run after the other B2B requests."
          }
        }
      ]
    }
  ]
}
