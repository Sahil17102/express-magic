{
  "info": {
    "_postman_id": "91d8af16-20bf-4aa5-b44d-delhivery-b2b",
    "name": "Express Magic - Delhivery B2B (LTL)",
    "description": "End-to-end checks for the admin-only Express Magic Delhivery B2B proxy. Save credentials in Admin > Courier Credentials first. Password Reset, Manifest, Update, Cancellation, Pickup, and Appointment requests mutate Delhivery state; run them deliberately.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [{ "key": "token", "value": "{{adminToken}}", "type": "string" }]
  },
  "event": [
    {
      "listen": "test",
      "script": {
        "type": "text/javascript",
        "exec": [
          "pm.test('HTTP status is successful', function () {",
          "  pm.expect(pm.response.code).to.be.within(200, 299);",
          "});",
          "var body = {};",
          "try { body = pm.response.json(); } catch (e) {}",
          "pm.test('proxy reports success', function () {",
          "  pm.expect(body.success).to.eql(true);",
          "});"
        ]
      }
    }
  ],
  "item": [
    {
      "name": "Authentication",
      "item": [
        {
          "name": "Password Reset (manual, mutating)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/delhivery/b2b/auth/password-reset",
            "description": "Sends a reset link for the registered Delhivery username. Do not include this request in routine collection runs.",
            "body": { "mode": "raw", "raw": "{\n  \"username\": \"{{delhiveryUsername}}\"\n}" }
          }
        },
        {
          "name": "Login / Validate Saved Credentials",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/delhivery/b2b/auth/login",
            "description": "Validates the saved Delhivery username/password. Express Magic caches the returned JWT until shortly before its 24-hour expiry and never exposes it to the browser. Concurrent courier requests share a single login call."
          }
        }
      ]
    },
    {
      "name": "Serviceability and Freight",
      "item": [
        {
          "name": "Pincode Serviceability",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/delhivery/b2b/serviceability/{{destinationPincode}}?weight={{weightGrams}}",
            "description": "Checks a six-digit pincode before any shipment operation. Weight is optional and expressed in grams. Express Magic checks both origin and consignee pincodes before B2B manifestation."
          }
        },
        {
          "name": "Expected TAT",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/delhivery/b2b/tat?origin_pin={{originPincode}}&destination_pin={{destinationPincode}}",
            "description": "Returns Delhivery's current network transit estimate in days for two valid six-digit pincodes. Express Magic forwards the request to GET /tat/estimate with the cached UMS bearer token and a unique X-Request-Id."
          }
        },
        {
          "name": "Freight Estimate",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/delhivery/b2b/freight/estimate",
            "description": "Estimates Delhivery B2B freight using centimetre dimensions and shipment weight in grams. Required values are validated before forwarding; cod_amount is required for COD, and the configured B2BR fop/fod mode is used when freight_mode is omitted.",
            "body": { "mode": "raw", "raw": "{\n  \"dimensions\": [{\"length_cm\": 10, \"width_cm\": 10, \"height_cm\": 10, \"box_count\": 1}],\n  \"weight_g\": {{weightGrams}},\n  \"cheque_payment\": false,\n  \"source_pin\": \"{{originPincode}}\",\n  \"consignee_pin\": \"{{destinationPincode}}\",\n  \"payment_mode\": \"prepaid\",\n  \"inv_amount\": 1000,\n  \"freight_mode\": \"fop\",\n  \"rov_insurance\": false\n}" }
          }
        },
        {
          "name": "Freight Charge Breakup",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/delhivery/b2b/freight/charges?lrns={{lrn}}",
            "description": "Returns the applicable charge breakdown for one or more comma-separated LRNs. Express Magic trims the list, enforces Delhivery's maximum of 25 LRNs, percent-encodes the comma-separated path value, and forwards it with the cached bearer token."
          }
        }
      ]
    },
    {
      "name": "Warehouses",
      "item": [
        {
          "name": "Create Warehouse (mutating)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/delhivery/b2b/warehouses",
            "description": "Registers a pickup warehouse before manifestation. The warehouse name is preserved exactly because Delhivery treats its case and spaces as significant. Required address data, schedules, weekday lists, GST format, and boolean options are validated before forwarding.",
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"{{warehouseName}}\",\n  \"pin_code\": \"{{originPincode}}\",\n  \"city\": \"Gurugram\",\n  \"state\": \"Haryana\",\n  \"country\": \"India\",\n  \"address_details\": {\"address\": \"Test warehouse address\", \"contact_person\": \"Operations\", \"phone_number\": \"9999999999\"},\n  \"same_as_fwd_add\": false,\n  \"business_hours\": {\"TUE\": {\"start_time\": \"07:00\", \"close_time\": \"08:30\"}},\n  \"pick_up_hours\": {\"TUE\": {\"start_time\": \"13:00\", \"close_time\": \"16:00\"}},\n  \"pick_up_days\": [\"TUE\"],\n  \"business_days\": [\"TUE\"],\n  \"ret_address\": {\"pin\": \"721657\", \"address\": \"test\"}\n}" }
          }
        },
        {
          "name": "Update Warehouse (mutating)",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/delhivery/b2b/warehouses",
            "description": "Updates a warehouse identified by its exact case/space-sensitive name. Nested address, return address, billing, schedule, weekday, QR, and appointment fields are validated. Express Magic uses Delhivery's cURL path first and retries the alternate documented environment path only for 404/405 responses.",
            "body": { "mode": "raw", "raw": "{\n  \"cl_warehouse_name\": \"{{warehouseName}}\",\n  \"update_dict\": {\n    \"city\": \"Faridabad\",\n    \"state\": \"Maharashtra\",\n    \"country\": \"India\",\n    \"address_details\": {\"address\": \"Updated warehouse address\", \"contact_person\": \"Operations Team\", \"phone_number\": \"9999999999\", \"email\": \"operations@example.com\", \"company\": \"Express Magic\"},\n    \"ret_address\": {\"address\": \"Return address\", \"city\": \"Gurugram\", \"state\": \"Haryana\", \"pin\": \"122001\", \"country\": \"INDIA\"}\n  }\n}" }
          }
        }
      ]
    },
    {
      "name": "Shipments",
      "item": [
        {
          "name": "Manifest Shipment (mutating)",
          "event": [{
            "listen": "test",
            "script": { "type": "text/javascript", "exec": [
              "var body = pm.response.json();",
              "var data = body.data || {};",
              "var jobId = data.job_id || data.request_id || (data.data || {}).job_id;",
              "var lrn = data.lrn || data.lrnum || (data.data || {}).lrn;",
              "if (jobId) pm.environment.set('manifestJobId', jobId);",
              "if (lrn) pm.environment.set('lrn', lrn);"
            ] }
          }],
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/delhivery/b2b/shipments/manifest",
            "description": "Creates a B2B shipment asynchronously and stores the returned job/request ID for Manifest Status. Multipart JSON fields are validated and normalized; pickup and drop-off alternatives, COD rules, invoice rules, dimensions, retail fields, and the 10-file/20-MB aggregate document limits are enforced. Enable doc_data and doc_file together when uploading invoice documents.",
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "pickup_location_name", "value": "{{warehouseName}}", "type": "text" },
                { "key": "payment_mode", "value": "prepaid", "type": "text" },
                { "key": "weight", "value": "{{weightGrams}}", "type": "text" },
                { "key": "dropoff_location", "value": "{\"consignee_name\":\"Postman Test\",\"address\":\"Test address\",\"city\":\"Mumbai\",\"state\":\"Maharashtra\",\"zip\":\"{{destinationPincode}}\",\"phone\":\"9999999999\",\"email\":\"test@example.com\"}", "type": "text" },
                { "key": "shipment_details", "value": "[{\"order_id\":\"POSTMAN-{{$timestamp}}\",\"box_count\":1,\"description\":\"Postman test shipment\",\"weight\":{{weightGrams}},\"waybills\":[],\"master\":true}]", "type": "text" },
                { "key": "dimensions", "value": "[{\"box_count\":1,\"length\":10,\"width\":10,\"height\":10}]", "type": "text" },
                { "key": "invoices", "value": "[{\"ewaybill\":\"\",\"inv_num\":\"POSTMAN-INV-{{$timestamp}}\",\"inv_amt\":1000,\"inv_qr_code\":\"\"}]", "type": "text" },
                { "key": "rov_insurance", "value": "false", "type": "text" },
                { "key": "enable_paperless_movement", "value": "false", "type": "text" },
                { "key": "freight_mode", "value": "fop", "type": "text" },
                { "key": "fm_pickup", "value": "false", "type": "text" },
                { "key": "billing_address", "value": "{\"name\":\"Billing Contact\",\"company\":\"Express Magic\",\"consignor\":\"Express Magic\",\"address\":\"Test billing address\",\"city\":\"Gurugram\",\"state\":\"Haryana\",\"pin\":\"{{originPincode}}\",\"phone\":\"9999999999\",\"pan_number\":\"ABCDE1234F\"}", "type": "text" },
                { "key": "callback", "value": "{\"uri\":\"{{documentCallbackUrl}}\",\"method\":\"POST\"}", "type": "text" },
                { "key": "doc_data", "value": "[{\"doc_type\":\"INVOICE_COPY\",\"doc_meta\":{\"invoice_num\":[\"POSTMAN-INV\"]}}]", "type": "text", "disabled": true },
                { "key": "doc_file", "type": "file", "src": "", "disabled": true }
              ]
            }
          }
        },
        {
          "name": "Manifest Status",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "var body = pm.response.json(); var data = body.data || {}; var lrn = data.lrn || data.lrnum || (data.data || {}).lrn; if (lrn) pm.environment.set('lrn', lrn);"
          ] } }],
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/delhivery/b2b/shipments/manifest/{{manifestJobId}}",
            "description": "Retrieves the LR and box/document AWBs using the asynchronous job_id. The booking workflow waits before its first status poll and retries with a bounded delay while Delhivery processes the manifest."
          }
        },
        {
          "name": "Update Shipment (mutating)",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "var body = pm.response.json(); var data = body.data || {}; var id = data.job_id || data.request_id || (data.data || {}).job_id; if (id) pm.environment.set('updateJobId', id);"
          ] } }],
          "request": {
            "method": "PUT",
            "url": "{{baseUrl}}/api/delhivery/b2b/shipments/{{lrn}}",
            "description": "Updates mutable fields for a manifested COD LR before last-mile dispatch. Prepaid LR updates are rejected. Multipart JSON, dimensions, invoices, callback/cb aliases, pincode, invoice metadata sequencing, file formats, the 10-file limit, and the 20-MB aggregate limit are validated before forwarding.",
            "body": { "mode": "formdata", "formdata": [
              { "key": "payment_mode", "value": "cod", "type": "text" },
              { "key": "cod_amount", "value": "0", "type": "text" },
              { "key": "consignee_name", "value": "Postman Updated Consignee", "type": "text" },
              { "key": "consignee_address", "value": "Updated consignee address", "type": "text" },
              { "key": "consignee_pincode", "value": "{{destinationPincode}}", "type": "text" },
              { "key": "consignee_phone", "value": "9999999999", "type": "text" },
              { "key": "weight_g", "value": "{{weightGrams}}", "type": "text" },
              { "key": "dimensions", "value": "[{\"width_cm\":5,\"height_cm\":4,\"length_cm\":3,\"box_count\":1}]", "type": "text" },
              { "key": "invoices", "value": "[{\"inv_number\":\"POSTMAN-INV\",\"inv_amount\":1000,\"qr_code\":\"\",\"ewaybill\":\"\"}]", "type": "text" },
              { "key": "callback", "value": "{\"uri\":\"{{documentCallbackUrl}}\",\"method\":\"POST\"}", "type": "text" },
              { "key": "invoice_files_meta", "value": "[{\"invoices\":[\"POSTMAN-INV\"]}]", "type": "text", "disabled": true },
              { "key": "invoice_file", "type": "file", "src": "", "disabled": true }
            ] }
          }
        },
        {
          "name": "Shipment Update Status",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/delhivery/b2b/shipments/update/{{updateJobId}}",
            "description": "Fetches the asynchronous Edit LR result using the job/request ID captured from Update Shipment. Delhivery may need processing time before returning a final status; retry this read-only request after a short gap when the job is still pending. Express Magic forwards job_id with the cached UMS bearer token."
          }
        },
        {
          "name": "Track Shipment",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/delhivery/b2b/shipments/{{lrn}}/tracking?all_wbns=true",
            "description": "Returns Delhivery's latest LR status only; historical scans are not supplied by this API. Set all_wbns=true to request child-waybill statuses or omit it for the master shipment. Express Magic maps all documented B2B statuses into local shipment, NDR, delivered, return, and lost states."
          }
        },
        {
          "name": "Book Last-Mile Appointment (mutating)",
          "event": [{
            "listen": "prerequest",
            "script": { "type": "text/javascript", "exec": [
              "function indiaDate(offsetDays) {",
              "  var value = new Date(Date.now() + (330 + offsetDays * 1440) * 60000);",
              "  return String(value.getUTCDate()).padStart(2, '0') + '/' + String(value.getUTCMonth() + 1).padStart(2, '0') + '/' + value.getUTCFullYear();",
              "}",
              "pm.environment.set('appointmentDate', indiaDate(1));",
              "pm.environment.set('appointmentExpiryDate', indiaDate(2));"
            ] }
          }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/delhivery/b2b/shipments/{{lrn}}/appointments",
            "description": "Books last-mile delivery after manifestation and before OFD. Dates use DD/MM/YYYY in India time, the appointment must be today or later, expiry cannot precede the appointment, only Delhivery's eight slots are accepted, and 1-5 PO numbers are required. Delhivery validates the promised-delivery-date and provider-stage constraints.",
            "body": { "mode": "raw", "raw": "{\n  \"date\": \"{{appointmentDate}}\",\n  \"appointment_slot\": \"12:00 PM-03:00 PM\",\n  \"po_number\": [\"NotApplicable\"],\n  \"appointment_id\": \"\",\n  \"po_expiry_date\": \"{{appointmentExpiryDate}}\"\n}" }
          }
        },
        {
          "name": "Cancel Shipment (destructive)",
          "request": {
            "method": "DELETE",
            "url": "{{baseUrl}}/api/delhivery/b2b/shipments/{{lrn}}",
            "description": "Cancels the manifested LRN through DELETE /lrn/cancel/{lrn}. Delhivery accepts cancellation only while its shipment is Manifested, In Transit, Pending, Open, or Scheduled and remains authoritative for that provider-side status check. Successful prepaid/COD cancellations transition to Returned in Delhivery."
          }
        }
      ]
    },
    {
      "name": "Pickups",
      "item": [
        {
          "name": "Create Pickup (mutating)",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "var body = pm.response.json(); var data = body.data || {}; var id = data.pickup_id || data.pur_id || (data.data || {}).pickup_id; if (id) pm.environment.set('pickupId', id);"
          ] } }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/delhivery/b2b/pickups",
            "body": { "mode": "raw", "raw": "{\n  \"client_warehouse\": \"{{warehouseName}}\",\n  \"pickup_date\": \"{{pickupDate}}\",\n  \"start_time\": \"10:00:00\",\n  \"expected_package_count\": 1\n}" }
          }
        },
        {
          "name": "Cancel Pickup (destructive)",
          "request": { "method": "DELETE", "url": "{{baseUrl}}/api/delhivery/b2b/pickups/{{pickupId}}" }
        }
      ]
    },
    {
      "name": "Labels and Documents",
      "item": [
        {
          "name": "Shipping Label",
          "request": { "method": "GET", "url": "{{baseUrl}}/api/delhivery/b2b/shipments/{{lrn}}/labels/a4" }
        },
        {
          "name": "LR Copy",
          "request": { "method": "GET", "url": "{{baseUrl}}/api/delhivery/b2b/shipments/{{lrn}}/lr-copy?lr_copy_type=SHIPPER%20COPY,LM%20POD" }
        },
        {
          "name": "Generate Shipping Labels (async)",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "var body = pm.response.json(); var data = body.data || {}; var id = data.job_id || data.request_id || (data.data || {}).job_id; if (id) pm.environment.set('documentJobId', id);"
          ] } }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/delhivery/b2b/documents/shipping_label",
            "body": { "mode": "raw", "raw": "{\n  \"lrns\": [\"{{lrn}}\"],\n  \"size\": \"a4\",\n  \"callback\": {\"uri\": \"{{documentCallbackUrl}}\", \"method\": \"POST\"}\n}" }
          }
        },
        {
          "name": "Generate LR Copies (async)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/delhivery/b2b/documents/lr_copy",
            "body": { "mode": "raw", "raw": "{\n  \"lrns\": [\"{{lrn}}\"],\n  \"lr_copy_type\": [\"SHIPPER COPY\", \"LM POD\"],\n  \"callback\": {\"uri\": \"{{documentCallbackUrl}}\", \"method\": \"POST\"}\n}" }
          }
        },
        {
          "name": "Generate Document Status",
          "request": { "method": "GET", "url": "{{baseUrl}}/api/delhivery/b2b/documents/shipping_label/{{documentJobId}}" }
        },
        {
          "name": "Download POD Document",
          "request": { "method": "GET", "url": "{{baseUrl}}/api/delhivery/b2b/documents?lrn={{lrn}}&doc_type=LM_POD&auto_download=false&version=latest" }
        }
      ]
    },
    {
      "name": "Session Cleanup",
      "item": [
        {
          "name": "Logout (optional)",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/delhivery/b2b/auth/logout",
            "description": "Invalidates the cached Delhivery JWT. This API is optional and should run after the other B2B requests."
          }
        }
      ]
    }
  ]
}
