# Public backend origin used for platform webhook registration.
# Must be HTTPS in production and must not include /api.
API_URL=https://cheerful-fulfillment-production-07ac.up.railway.app
CORS_ALLOWED_ORIGINS=https://express-magic-production-608b.up.railway.app,https://express-magic-production.up.railway.app

# Client login OTP delivery.
# screen = do not require SMTP; API returns the OTP so the client can show it on screen.
# email = send only by email; both = send email and also return it for testing.
AUTH_OTP_DELIVERY=screen

# Admin seed/reset credentials used by `npm run seed:admin`.
ADMIN_SEED_EMAIL=admin@shiplifi.com
ADMIN_SEED_PASSWORD=Admin@12345!

# Delhivery Tracking Push API / Scan Push callback URLs shown in admin courier settings.
# Defaults are derived from API_URL. Override only if Delhivery must use a different public host.
# DELHIVERY_SCAN_PUSH_WEBHOOK_URL=https://api.fgship.in/api/webhook/delhivery/scan
# DELHIVERY_DOCUMENT_PUSH_WEBHOOK_URL=https://api.fgship.in/api/webhook/delhivery/document
# DELHIVERY_LEGACY_WEBHOOK_URL=https://api.fgship.in/api/webhook/delhivery/order

# Optional Ekart webhook overrides.
# EKART_WEBHOOK_URL=https://api.fgship.in/api/webhook/ekart
# EKART_TRACK_WEBHOOK_URL=https://api.fgship.in/api/webhook/ekart/track
# EKART_WEBHOOK_SECRET=your_ekart_webhook_secret

# Shadowfax webhook URL and Basic Auth for all Shadowfax client-push topics.
# Use this same URL for FWD Marketplace, FWD Warehouse, Return Seller,
# Return Origin, Seller Delivery, and Invoice.
# SHADOWFAX_WEBHOOK_URL=https://api.fgship.in/webhooks/shadowfax
# SHADOWFAX_WEBHOOK_BASIC_USERNAME=your_shadowfax_webhook_username
# SHADOWFAX_WEBHOOK_BASIC_PASSWORD=your_shadowfax_webhook_password

# Shopify OAuth app credentials from the Shopify Dev Dashboard.
# Add this exact redirect URL in Shopify:
#   https://api.fgship.in/api/integrations/shopify/oauth/callback
SHOPIFY_CLIENT_ID=your_shopify_client_id
SHOPIFY_CLIENT_SECRET=your_shopify_client_secret
SHOPIFY_SCOPES=read_orders,write_orders,read_customers,read_webhooks,write_webhooks,read_merchant_managed_fulfillment_orders,write_merchant_managed_fulfillment_orders
SHOPIFY_API_VERSION=2026-07
SHOPIFY_OAUTH_SUCCESS_URL=https://client.fgship.in/channels/connected
SHOPIFY_USE_EXPIRING_OFFLINE_TOKENS=true
# Leave false when scopes are managed in the Shopify Dev Dashboard app version.
SHOPIFY_SEND_OAUTH_SCOPE=false
# Mandatory Shopify App Store privacy/compliance webhook URI:
#   https://api.fgship.in/api/webhooks/shopify/compliance
# Add this URI to shopify.app.toml with compliance_topics:
#   customers/data_request, customers/redact, shop/redact

# Optional emergency-only fallback. Leave disabled for the new OAuth workflow.
SHOPIFY_ALLOW_LEGACY_MANUAL_AUTH=false

# Optional shared fallback secret for WooCommerce webhook HMAC verification.
# The backend generates a per-store secret during connection when this is omitted.
# WOOCOMMERCE_WEBHOOK_SECRET=

# Optional timeout for Shopify/WooCommerce/Magento/Wix platform API calls.
PLATFORM_API_TIMEOUT_MS=15000

# Razorpay wallet recharge.
# Do not commit live values. Set these on the VPS in backend/.env.production
# and in backend/.env.development if you want to run real local checkout tests.
# Live keys accept real payments. Use test-mode keys instead if you want sandbox testing.
RAZORPAY_MODE=live
RAZORPAY_KEY_ID_PROD=rzp_live_xxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET_PROD=your_razorpay_key_secret
RAZORPAY_MERCHANT_ID_PROD=your_razorpay_mid
# Required only if Razorpay webhooks are enabled in the Razorpay dashboard.
# RAZORPAY_WEBHOOK_SECRET_PROD=your_razorpay_webhook_secret

# Optional local-only variables for the WooCommerce credential checker.
# Do not commit real merchant credentials.
# WOOCOMMERCE_STORE_URL=https://yourstore.com
# WOOCOMMERCE_CONSUMER_KEY=ck_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# WOOCOMMERCE_CONSUMER_SECRET=cs_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# WOOCOMMERCE_CHECK_WRITE=false

# Email sender identity used by the backend mailers.
# Set this to a verified FGShip mailbox in production.
# EMAIL_FROM=no-reply@fgship.in
# EMAIL_FROM_NAME=FGShip
# GOOGLE_SMTP_USER=no-reply@fgship.in
# GOOGLE_SMTP_PASSWORD=
# SMTP_HOST=smtp.hostinger.com
# SMTP_PORT=465
# SMTP_SECURE=true
